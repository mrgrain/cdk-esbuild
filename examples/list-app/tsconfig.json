{
  "compilerOptions": {
    // Settings for Node.js >= 12.9.0
    "lib": ["dom", "es2020"],
    "module": "commonjs",
    "target": "es2019",

    // React support
    "jsx": "react",
    "esModuleInterop": true,

    // Enable super strict setting
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "resolveJsonModule": false,

    // Function code never has to be compiled outside zeit/ncc and ts-jest
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["cdk.out", "node_modules"]
}
